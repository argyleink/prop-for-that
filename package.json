{
  "name": "prop-for-that",
  "version": "0.7.3",
  "description": "Expose what JavaScript knows but CSS can't see, as batched, diffed CSS custom properties.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/argyleink/prop-for-that.git"
  },
  "author": "Adam Argyle (https://github.com/argyleink)",
  "keywords": [
    "css",
    "custom-properties",
    "css-variables",
    "reactive",
    "state",
    "dom",
    "battery",
    "network",
    "geolocation",
    "device-orientation",
    "scroll-velocity",
    "fps"
  ],
  "sideEffects": [
    "./dist/auto.js",
    "./dist/auto.cjs",
    "./dist/head.js",
    "./dist/head.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js",
      "require": "./dist/auto.cjs"
    },
    "./head": {
      "types": "./dist/head.d.ts",
      "import": "./dist/head.js",
      "require": "./dist/head.cjs"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js",
      "require": "./dist/plugins.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "llms.txt",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "build:demos": "cd demos && npm install && npm run build",
    "build:docs": "cd docs && npm install && DOCS_BASE=/docsite npm run build",
    "build:site": "npm run build:demos && npm run build:docs && node scripts/assemble-site.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
